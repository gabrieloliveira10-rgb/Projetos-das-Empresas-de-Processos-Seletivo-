import os
import requests
def send_whatsapp_message(to_phone: str, message: str):
    """
    Envia mensagem via Z-API.
    Ajuste o endpoint/headers se sua configuração Z-API for diferente.
    """
    instance = os.environ["ZAPI_INSTANCE"]
    api_token = os.environ["ZAPI_API_TOKEN"]
    base = os.environ.get("ZAPI_API_BASE", "https://api.z-api.io")
    url = f"{base}/instances/{instance}/messages/sendText"
    headers = {
        "Content-Type": "application/json",
        "Authorization": f"Bearer {api_token}",
    }
    payload = {
        "phone": to_phone,
        "message": message,
    }
    resp = requests.post(url, json=payload, headers=headers, timeout=30)
    resp.raise_for_status()
    return resp.json()